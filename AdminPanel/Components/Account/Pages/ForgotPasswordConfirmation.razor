@page "/Account/ForgotPasswordConfirmation"
@layout AuthLayout

<PageTitle>Forgot password confirmation</PageTitle>

<div class="auth-shell">
    <div class="auth-card">
        <div class="brand">Freelance Projects</div>
        <h1>Check your email</h1>
        <p class="muted" role="alert">
            If that account exists, we've sent a link to reset your password.
        </p>
        <div class="auth-footer-links">
            <a href="Account/Login">Back to log in</a>
        </div>
    </div>
</div>
